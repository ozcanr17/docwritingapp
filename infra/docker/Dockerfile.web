FROM node:22-alpine AS build
RUN corepack enable && corepack prepare pnpm@9.15.9 --activate
WORKDIR /app
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json turbo.json tsconfig.base.json ./
COPY apps/web ./apps/web
ARG VITE_API_URL=http://localhost:3001
ARG VITE_COLLAB_URL=ws://localhost:3002
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_COLLAB_URL=$VITE_COLLAB_URL
RUN pnpm install --frozen-lockfile --filter @docsys/web...
RUN pnpm --filter @docsys/web build

FROM nginx:1.27-alpine AS runtime
COPY infra/docker/nginx.web.conf /etc/nginx/conf.d/default.conf
COPY infra/docker/nginx.security.conf /etc/nginx/snippets/security-headers.conf
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=15s --timeout=3s --retries=5 CMD wget -q -O /dev/null http://127.0.0.1/health || exit 1
