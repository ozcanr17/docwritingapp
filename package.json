{
  "name": "docsys",
  "private": true,
  "version": "0.1.1",
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "exceljs>uuid": "11.1.1"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "bash infra/scripts/dev-up.sh",
    "dev:down": "bash infra/scripts/dev-down.sh",
    "seed": "node infra/scripts/seed-admin.mjs",
    "build": "turbo run build --filter=!@docsys/desktop",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck --filter=!@docsys/desktop",
    "desktop:typecheck": "pnpm --filter @docsys/desktop typecheck",
    "desktop:check": "pnpm --filter @docsys/desktop check",
    "desktop:build": "pnpm --filter @docsys/desktop build",
    "verify": "pnpm db:validate && pnpm typecheck && pnpm lint && pnpm scan:chars && pnpm --filter @docsys/web test && pnpm --filter @docsys/api test && pnpm --filter @docsys/worker test && pnpm build",
    "db:format": "pnpm --filter @docsys/database format",
    "db:validate": "pnpm --filter @docsys/database validate",
    "db:migrate": "pnpm --filter @docsys/database migrate:dev",
    "scan:chars": "bash infra/scripts/scan-forbidden-chars.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8"
  }
}
