{
  "name": "docsys",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:format": "pnpm --filter @docsys/database format",
    "db:validate": "pnpm --filter @docsys/database validate",
    "db:migrate": "pnpm --filter @docsys/database migrate:dev",
    "scan:chars": "bash infra/scripts/scan-forbidden-chars.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8"
  }
}
