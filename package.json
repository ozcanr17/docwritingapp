{
  "name": "reqtrack",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:format": "pnpm --filter @reqtrack/database format",
    "db:validate": "pnpm --filter @reqtrack/database validate",
    "db:migrate": "pnpm --filter @reqtrack/database migrate:dev",
    "scan:chars": "bash infra/scripts/scan-forbidden-chars.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
