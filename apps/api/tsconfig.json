{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "exactOptionalPropertyTypes": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "src"
  ]
}
