{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DocSys",
  "version": "0.2.0",
  "identifier": "com.docsys.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../web dev --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm --dir ../web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; connect-src 'self' ipc: http: https: ws: wss:; font-src 'self' data:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "DocSys",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": [
          "English",
          "Turkish"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEMjZEQzIyODlCMkE5RTcKUldUbnFiS0pJdHdtZlJLTVk5ZEU3VTYxblU3a3o2SnJFQ21ZRUJPZ2pyOTZoUHNIcGhoMWZxZ2sK",
      "endpoints": [
        "https://github.com/ozcanr17/docwritingapp/releases/latest/download/latest.json"
      ]
    }
  }
}
